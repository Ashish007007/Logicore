<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Logicore.View.MaintenancePage"
             Title="Service Logs"
             BackgroundColor="#0f1923">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Log" Command="{Binding ShowAddFormCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <Frame Grid.Row="0" IsVisible="{Binding HasError}" BackgroundColor="#3d1515"
               BorderColor="#e74c3c" CornerRadius="0" Padding="12">
            <Label Text="{Binding ErrorMessage}" TextColor="#e74c3c" FontSize="13"/>
        </Frame>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}" RefreshColor="#2563eb">
            <CollectionView ItemsSource="{Binding Logs}" EmptyView="No maintenance logs found.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1e2d3d" CornerRadius="12"
                               BorderColor="#2a3f54" Padding="14" Margin="12,6">
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding VehicleName}"
                                           TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Cost, StringFormat='₹{0:N0}'}"
                                           TextColor="#e74c3c" FontAttributes="Bold" FontSize="14"/>
                                </Grid>
                                <Label Text="{Binding ServiceType}" TextColor="#2563eb" FontSize="13"/>
                                <StackLayout Orientation="Horizontal" Spacing="16">
                                    <Label Text="{Binding ServiceDate, StringFormat='Date: {0:dd MMM yyyy}'}"
                                           TextColor="#8899aa" FontSize="12"/>
                                    <Label Text="{Binding NextServiceDue, StringFormat='Next: {0:dd MMM yyyy}'}"
                                           TextColor="#f39c12" FontSize="12"/>
                                </StackLayout>
                                <Label Text="{Binding Remarks}" TextColor="#8899aa" FontSize="12"
                                       IsVisible="{Binding Remarks, Converter={StaticResource NotNullConverter}}"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Add Form Modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsFormVisible}"
              BackgroundColor="#80000000">
            <Frame BackgroundColor="#1e2d3d" CornerRadius="20" BorderColor="#2a3f54"
                   Padding="24" VerticalOptions="Center" Margin="16" HasShadow="True">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Log Maintenance" TextColor="White"
                               FontSize="20" FontAttributes="Bold"/>

                        <!-- Auto In Shop notice -->
                        <Frame BackgroundColor="#1a2c1a" BorderColor="#2ecc71" CornerRadius="8" Padding="10">
                            <Label Text="⚠️ Saving this will automatically set the vehicle status to 'In Shop' and remove it from dispatcher pool."
                                   TextColor="#2ecc71" FontSize="12"/>
                        </Frame>

                        <Label Text="Vehicle *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding AllVehicles}"
                                    ItemDisplayBinding="{Binding VehicleName}"
                                    SelectedItem="{Binding SelectedVehicleForMaint}"
                                    TextColor="White" BackgroundColor="Transparent"
                                    TitleColor="#4a5568" Title="Select Vehicle"/>
                        </Frame>

                        <Label Text="Service Type *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding ServiceTypes}"
                                    SelectedItem="{Binding FormServiceType}"
                                    TextColor="White" BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="Service Date *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="4">
                            <DatePicker Date="{Binding FormServiceDate}"
                                        TextColor="White" BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="Next Service Due" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="4">
                            <DatePicker Date="{Binding FormNextServiceDue}"
                                        TextColor="White" BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="Cost (₹)" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormCost}" Placeholder="0"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   Keyboard="Numeric" BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Remarks" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="4">
                            <Editor Text="{Binding FormRemarks}" Placeholder="Optional notes..."
                                    PlaceholderColor="#4a5568" TextColor="White"
                                    BackgroundColor="Transparent" HeightRequest="70"/>
                        </Frame>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                            <Button Grid.Column="0" Text="Cancel"
                                    Command="{Binding HideFormCommand}"
                                    BackgroundColor="#253545" TextColor="White"
                                    CornerRadius="10" HeightRequest="48"/>
                            <Button Grid.Column="1" Text="🔧 Save Log"
                                    Command="{Binding SaveLogCommand}"
                                    BackgroundColor="#f39c12" TextColor="White"
                                    FontAttributes="Bold" CornerRadius="10" HeightRequest="48"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
