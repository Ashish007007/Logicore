<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Logicore.View.TripPage"
             Title="Trip Dispatcher"
             BackgroundColor="#0f1923">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Dispatch" Command="{Binding ShowAddFormCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Filter -->
        <Frame Grid.Row="0" BackgroundColor="#1e2d3d" BorderColor="#2a3f54"
               CornerRadius="0" Padding="12,8">
            <Picker Title="Filter Status" ItemsSource="{Binding StatusFilters}"
                    SelectedItem="{Binding FilterStatus}"
                    TextColor="White" BackgroundColor="Transparent" TitleColor="#8899aa"/>
        </Frame>

        <!-- Error -->
        <Frame Grid.Row="1" IsVisible="{Binding HasError}" BackgroundColor="#3d1515"
               BorderColor="#e74c3c" CornerRadius="0" Padding="12">
            <Label Text="{Binding ErrorMessage}" TextColor="#e74c3c" FontSize="13"/>
        </Frame>

        <!-- Trip list -->
        <RefreshView Grid.Row="2" Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}" RefreshColor="#2563eb">
            <CollectionView ItemsSource="{Binding Trips}"
                            EmptyView="No trips found.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1e2d3d" CornerRadius="12"
                               BorderColor="#2a3f54" Padding="14" Margin="12,6">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label TextColor="White" FontAttributes="Bold" FontSize="15">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} → {1}">
                                                    <Binding Path="Origin"/>
                                                    <Binding Path="Destination"/>
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Text="{Binding VehicleName}" TextColor="#8899aa" FontSize="12"/>
                                    </VerticalStackLayout>
                                    <Frame Grid.Column="1" CornerRadius="6" Padding="8,3" VerticalOptions="Start"
                                           BackgroundColor="#253545" BorderColor="#2a3f54">
                                        <Label Text="{Binding Status}" FontSize="11"
                                               TextColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                    </Frame>
                                </Grid>

                                <StackLayout Orientation="Horizontal" Spacing="16">
                                    <Label Text="{Binding DriverName}" TextColor="#8899aa" FontSize="12"/>
                                    <Label Text="{Binding CargoWeight, StringFormat='{0}kg'}"
                                           TextColor="#8899aa" FontSize="12"/>
                                    <Label Text="{Binding StartDate, StringFormat='{0:dd MMM}'}"
                                           TextColor="#8899aa" FontSize="12"/>
                                </StackLayout>

                                <!-- Action buttons for dispatched trips -->
                                <StackLayout Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                             IsVisible="{Binding Status, Converter={StaticResource StatusVisibleConverter}, ConverterParameter='Dispatched'}">
                                    <Button Text="✅ Complete" FontSize="12" HeightRequest="34"
                                            BackgroundColor="#163a2e" TextColor="#2ecc71" CornerRadius="8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompleteTripCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Text="❌ Cancel" FontSize="12" HeightRequest="34"
                                            BackgroundColor="#3d1515" TextColor="#e74c3c" CornerRadius="8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelTripCommand}"
                                            CommandParameter="{Binding .}"/>
                                </StackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Dispatch Form Modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsFormVisible}"
              BackgroundColor="#80000000">
            <Frame BackgroundColor="#1e2d3d" CornerRadius="20" BorderColor="#2a3f54"
                   Padding="24" VerticalOptions="Center" Margin="16" HasShadow="True">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Dispatch New Trip" TextColor="White"
                               FontSize="20" FontAttributes="Bold"/>

                        <Label Text="Select Vehicle *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding AvailableVehicles}"
                                    ItemDisplayBinding="{Binding VehicleName}"
                                    SelectedItem="{Binding SelectedVehicleForTrip}"
                                    TextColor="White" BackgroundColor="Transparent"
                                    TitleColor="#4a5568" Title="Available Vehicles"/>
                        </Frame>

                        <Label Text="Select Driver *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding AvailableDrivers}"
                                    ItemDisplayBinding="{Binding DriverName}"
                                    SelectedItem="{Binding SelectedDriverForTrip}"
                                    TextColor="White" BackgroundColor="Transparent"
                                    TitleColor="#4a5568" Title="Available Drivers"/>
                        </Frame>

                        <Label Text="Cargo Weight (kg) *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormCargoWeight}" Placeholder="0"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   Keyboard="Numeric" BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Origin *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormOrigin}" Placeholder="City / Warehouse"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Destination *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormDestination}" Placeholder="City / Warehouse"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Start Date *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="4">
                            <DatePicker Date="{Binding FormStartDate}" TextColor="White"
                                        BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="Start Odometer (km)" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormStartOdometer}" Placeholder="0"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   Keyboard="Numeric" BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                            <Button Grid.Column="0" Text="Cancel"
                                    Command="{Binding HideFormCommand}"
                                    BackgroundColor="#253545" TextColor="White"
                                    CornerRadius="10" HeightRequest="48"/>
                            <Button Grid.Column="1" Text="🚀 Dispatch"
                                    Command="{Binding DispatchTripCommand}"
                                    BackgroundColor="#2563eb" TextColor="White"
                                    FontAttributes="Bold" CornerRadius="10" HeightRequest="48"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>

        <!-- Complete Trip Modal -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsCompletingTrip}"
              BackgroundColor="#80000000">
            <Frame BackgroundColor="#1e2d3d" CornerRadius="20" BorderColor="#2a3f54"
                   Padding="24" VerticalOptions="Center" Margin="32" HasShadow="True">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Complete Trip" TextColor="White"
                           FontSize="20" FontAttributes="Bold"/>
                    <Label Text="Enter final odometer reading:" TextColor="#8899aa" FontSize="14"/>
                    <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="50">
                        <Entry Text="{Binding FormEndOdometer}" Placeholder="End Odometer (km)"
                               PlaceholderColor="#4a5568" TextColor="White"
                               Keyboard="Numeric" BackgroundColor="Transparent"
                               Margin="10,0" FontSize="18"/>
                    </Frame>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Cancel"
                                Command="{Binding HideFormCommand}"
                                BackgroundColor="#253545" TextColor="White"
                                CornerRadius="10" HeightRequest="48"/>
                        <Button Grid.Column="1" Text="✅ Confirm"
                                BackgroundColor="#163a2e" TextColor="#2ecc71"
                                FontAttributes="Bold" CornerRadius="10" HeightRequest="48"
                                Clicked="OnConfirmCompleteClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
