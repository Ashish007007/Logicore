<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Logicore.View.VehiclePage"
             Title="Vehicle Registry"
             BackgroundColor="#0f1923">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add" Command="{Binding ShowAddFormCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Status filter picker -->
        <Frame Grid.Row="0" BackgroundColor="#1e2d3d" BorderColor="#2a3f54"
               CornerRadius="0" Padding="12,8">
            <Picker Title="Filter by Status" ItemsSource="{Binding StatusFilters}"
                    SelectedItem="{Binding FilterStatus}"
                    TextColor="White" BackgroundColor="Transparent"
                    TitleColor="#8899aa"/>
        </Frame>

        <!-- Error banner -->
        <Frame Grid.Row="1" IsVisible="{Binding HasError}" BackgroundColor="#3d1515"
               BorderColor="#e74c3c" CornerRadius="0" Padding="12">
            <Label Text="{Binding ErrorMessage}" TextColor="#e74c3c" FontSize="13"/>
        </Frame>

        <!-- Main list -->
        <RefreshView Grid.Row="2" Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}" RefreshColor="#2563eb">
            <CollectionView ItemsSource="{Binding Vehicles}"
                            EmptyView="No vehicles found. Tap + Add to get started.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1e2d3d" CornerRadius="12"
                               BorderColor="#2a3f54" Padding="14" Margin="12,6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                                <!-- Vehicle name + plate -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding VehicleName}"
                                       TextColor="White" FontAttributes="Bold" FontSize="16"/>
                                <Frame Grid.Row="0" Grid.Column="1"
                                       BackgroundColor="#253545" BorderColor="#2a3f54"
                                       CornerRadius="6" Padding="8,3" VerticalOptions="Start">
                                    <Label Text="{Binding Status}" FontSize="11"
                                           TextColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                </Frame>

                                <!-- Info row -->
                                <StackLayout Grid.Row="1" Grid.ColumnSpan="2"
                                             Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                    <Label Text="{Binding LicensePlate}" TextColor="#8899aa" FontSize="12"/>
                                    <Label Text="{Binding VehicleType}" TextColor="#8899aa" FontSize="12"/>
                                    <Label Text="{Binding MaxCapacityKg, StringFormat='{0}kg max'}"
                                           TextColor="#8899aa" FontSize="12"/>
                                </StackLayout>

                                <!-- Action buttons -->
                                <StackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                             Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                                    <Button Text="✏️ Edit" FontSize="12" HeightRequest="34"
                                            BackgroundColor="#253545" TextColor="White" CornerRadius="8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShowAddFormCommand}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Text="🗑️ Delete" FontSize="12" HeightRequest="34"
                                            BackgroundColor="#3d1515" TextColor="#e74c3c" CornerRadius="8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteVehicleCommand}"
                                            CommandParameter="{Binding .}"/>
                                </StackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Add/Edit Form Modal overlay -->
        <Grid Grid.RowSpan="3" IsVisible="{Binding IsFormVisible}"
              BackgroundColor="#80000000">
            <Frame BackgroundColor="#1e2d3d" CornerRadius="20" BorderColor="#2a3f54"
                   Padding="24" VerticalOptions="Center" Margin="16" HasShadow="True">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{Binding FormTitle}" TextColor="White"
                               FontSize="20" FontAttributes="Bold"/>

                        <Label Text="Vehicle Name *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormVehicleName}" PlaceholderColor="#4a5568"
                                   Placeholder="e.g. Van-05" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Vehicle Type *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding VehicleTypes}"
                                    SelectedItem="{Binding FormVehicleType}"
                                    TextColor="White" BackgroundColor="Transparent" TitleColor="#4a5568"/>
                        </Frame>

                        <Label Text="License Plate *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormLicensePlate}" PlaceholderColor="#4a5568"
                                   Placeholder="GJ-05-XX-0000" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Max Capacity (kg) *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormMaxCapacity}" PlaceholderColor="#4a5568"
                                   Placeholder="500" TextColor="White" Keyboard="Numeric"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Odometer (km)" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormOdometer}" PlaceholderColor="#4a5568"
                                   Placeholder="0" TextColor="White" Keyboard="Numeric"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="Acquisition Cost (₹)" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormAcquisitionCost}" PlaceholderColor="#4a5568"
                                   Placeholder="0" TextColor="White" Keyboard="Numeric"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                            <Button Grid.Column="0" Text="Cancel"
                                    Command="{Binding HideFormCommand}"
                                    BackgroundColor="#253545" TextColor="White"
                                    CornerRadius="10" HeightRequest="48"/>
                            <Button Grid.Column="1" Text="Save Vehicle"
                                    Command="{Binding SaveVehicleCommand}"
                                    BackgroundColor="#2563eb" TextColor="White"
                                    FontAttributes="Bold" CornerRadius="10" HeightRequest="48"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
