<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Logicore.View.DriverPage"
             Title="Driver Profiles"
             BackgroundColor="#0f1923">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add" Command="{Binding ShowAddFormCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">

        <Frame Grid.Row="0" IsVisible="{Binding HasError}" BackgroundColor="#3d1515"
               BorderColor="#e74c3c" CornerRadius="0" Padding="12">
            <Label Text="{Binding ErrorMessage}" TextColor="#e74c3c" FontSize="13"/>
        </Frame>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}" RefreshColor="#2563eb">
            <CollectionView ItemsSource="{Binding Drivers}"
                            EmptyView="No drivers found.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1e2d3d" CornerRadius="12"
                               BorderColor="#2a3f54" Padding="14" Margin="12,6">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!-- Avatar -->
                                <Frame Grid.Column="0" BackgroundColor="#253545"
                                       CornerRadius="24" WidthRequest="48" HeightRequest="48"
                                       Padding="0" BorderColor="#2a3f54">
                                    <Label Text="👤" FontSize="24"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding DriverName}" TextColor="White"
                                           FontAttributes="Bold" FontSize="15"/>
                                    <Label Text="{Binding LicenseNumber}" TextColor="#8899aa" FontSize="12"/>
                                    <StackLayout Orientation="Horizontal" Spacing="10">
                                        <Label Text="{Binding LicenseCategory}" TextColor="#8899aa" FontSize="12"/>
                                        <Label Text="{Binding SafetyScore, StringFormat='⭐ {0}'}"
                                               TextColor="#f39c12" FontSize="12"/>
                                        <Label Text="{Binding LicenseExpiry, StringFormat='Exp: {0:MM/yy}'}"
                                               TextColor="#8899aa" FontSize="12"/>
                                    </StackLayout>
                                </VerticalStackLayout>

                                <!-- Status + actions -->
                                <VerticalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                    <Frame BackgroundColor="#253545" BorderColor="#2a3f54"
                                           CornerRadius="6" Padding="8,3">
                                        <Label Text="{Binding Status}" FontSize="10"
                                               TextColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                    </Frame>
                                    <Button Text="Edit" FontSize="11" HeightRequest="28"
                                            BackgroundColor="#2563eb" TextColor="White" CornerRadius="6"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShowAddFormCommand}"
                                            CommandParameter="{Binding .}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Add/Edit Form -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsFormVisible}"
              BackgroundColor="#80000000">
            <Frame BackgroundColor="#1e2d3d" CornerRadius="20" BorderColor="#2a3f54"
                   Padding="24" VerticalOptions="Center" Margin="16" HasShadow="True">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding FormTitle}" TextColor="White"
                               FontSize="20" FontAttributes="Bold"/>

                        <Label Text="Driver Name *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormDriverName}" Placeholder="Full Name"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="License Number *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormLicenseNumber}" Placeholder="DL-XX-XXXX-XXXXXXX"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Label Text="License Category *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0">
                            <Picker ItemsSource="{Binding LicenseCategories}"
                                    SelectedItem="{Binding FormLicenseCategory}"
                                    TextColor="White" BackgroundColor="Transparent"/>
                        </Frame>

                        <Label Text="License Expiry *" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="4">
                            <DatePicker Date="{Binding FormLicenseExpiry}"
                                        TextColor="White" BackgroundColor="Transparent"
                                        MinimumDate="{x:Static sys:DateTime.Today}"
                                        xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                        </Frame>

                        <Label Text="Safety Score (0-100)" TextColor="#8899aa" FontSize="13"/>
                        <Frame BackgroundColor="#253545" BorderColor="#2a3f54" CornerRadius="8" Padding="0" HeightRequest="46">
                            <Entry Text="{Binding FormSafetyScore}" Placeholder="100"
                                   PlaceholderColor="#4a5568" TextColor="White"
                                   Keyboard="Numeric" BackgroundColor="Transparent" Margin="10,0"/>
                        </Frame>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                            <Button Grid.Column="0" Text="Cancel"
                                    Command="{Binding HideFormCommand}"
                                    BackgroundColor="#253545" TextColor="White"
                                    CornerRadius="10" HeightRequest="48"/>
                            <Button Grid.Column="1" Text="Save Driver"
                                    Command="{Binding SaveDriverCommand}"
                                    BackgroundColor="#2563eb" TextColor="White"
                                    FontAttributes="Bold" CornerRadius="10" HeightRequest="48"/>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
