<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Logicore"
             xmlns:converters="clr-namespace:Logicore.Converters"
             x:Class="Logicore.App">
    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- ── Converters ───────────────────────────────────────────────── -->
            <converters:StatusColorConverter   x:Key="StatusColorConverter"/>
            <converters:BusyTextConverter      x:Key="BusyTextConverter"/>
            <converters:NotNullConverter       x:Key="NotNullConverter"/>
            <converters:StatusVisibleConverter x:Key="StatusVisibleConverter"/>
            <converters:InverseBoolConverter   x:Key="InverseBoolConverter"/>

            <!-- ── Color Palette ────────────────────────────────────────────── -->
            <Color x:Key="PageBg">#0f1923</Color>
            <Color x:Key="CardBg">#1e2d3d</Color>
            <Color x:Key="InputBg">#253545</Color>
            <Color x:Key="BorderColor">#2a3f54</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#8899aa</Color>
            <Color x:Key="TextMuted">#4a5568</Color>
            <Color x:Key="AccentBlue">#2563eb</Color>
            <Color x:Key="AccentGreen">#2ecc71</Color>
            <Color x:Key="AccentOrange">#f39c12</Color>
            <Color x:Key="AccentRed">#e74c3c</Color>
            <Color x:Key="AccentTeal">#3498db</Color>

            <!-- ── Global Styles ────────────────────────────────────────────── -->

            <!-- Shell / Navigation bar -->
            <Style TargetType="Shell" ApplyToDerivedTypes="True">
                <Setter Property="Shell.BackgroundColor"       Value="{StaticResource CardBg}"/>
                <Setter Property="Shell.ForegroundColor"       Value="{StaticResource TextPrimary}"/>
                <Setter Property="Shell.TitleColor"            Value="{StaticResource TextPrimary}"/>
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource CardBg}"/>
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource AccentBlue}"/>
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMuted}"/>
            </Style>

            <!-- Default ContentPage background -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBg}"/>
            </Style>

            <!-- Label defaults -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontFamily" Value="OpenSansRegular"/>
            </Style>

            <!-- Entry defaults -->
            <Style TargetType="Entry">
                <Setter Property="TextColor"         Value="{StaticResource TextPrimary}"/>
                <Setter Property="PlaceholderColor"  Value="{StaticResource TextMuted}"/>
                <Setter Property="BackgroundColor"   Value="Transparent"/>
                <Setter Property="ClearButtonVisibility" Value="WhileEditing"/>
            </Style>

            <!-- Editor defaults -->
            <Style TargetType="Editor">
                <Setter Property="TextColor"        Value="{StaticResource TextPrimary}"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
                <Setter Property="BackgroundColor"  Value="Transparent"/>
            </Style>

            <!-- Picker defaults -->
            <Style TargetType="Picker">
                <Setter Property="TextColor"       Value="{StaticResource TextPrimary}"/>
                <Setter Property="TitleColor"      Value="{StaticResource TextMuted}"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
            </Style>

            <!-- DatePicker defaults -->
            <Style TargetType="DatePicker">
                <Setter Property="TextColor"       Value="{StaticResource TextPrimary}"/>
                <Setter Property="BackgroundColor" Value="Transparent"/>
            </Style>

            <!-- Frame / card defaults -->
            <Style TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
                <Setter Property="BorderColor"     Value="{StaticResource BorderColor}"/>
                <Setter Property="CornerRadius"    Value="12"/>
                <Setter Property="HasShadow"       Value="False"/>
            </Style>

            <!-- Primary action button -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                <Setter Property="TextColor"       Value="White"/>
                <Setter Property="FontAttributes"  Value="Bold"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="HeightRequest"   Value="48"/>
            </Style>

            <!-- Secondary / cancel button -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
                <Setter Property="TextColor"       Value="{StaticResource TextPrimary}"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="HeightRequest"   Value="48"/>
            </Style>

            <!-- Danger button -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#3d1515"/>
                <Setter Property="TextColor"       Value="{StaticResource AccentRed}"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="HeightRequest"   Value="48"/>
            </Style>

            <!-- Success button -->
            <Style x:Key="SuccessButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#163a2e"/>
                <Setter Property="TextColor"       Value="{StaticResource AccentGreen}"/>
                <Setter Property="FontAttributes"  Value="Bold"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="HeightRequest"   Value="48"/>
            </Style>

            <!-- Input frame wrapper -->
            <Style x:Key="InputFrame" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
                <Setter Property="BorderColor"     Value="{StaticResource BorderColor}"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="HeightRequest"   Value="46"/>
            </Style>

            <!-- Section header label -->
            <Style x:Key="SectionHeader" TargetType="Label">
                <Setter Property="TextColor"      Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize"        Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="Margin"         Value="0,8,0,4"/>
            </Style>

            <!-- Field label -->
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize"   Value="13"/>
            </Style>

            <!-- KPI value label -->
            <Style x:Key="KpiValue" TargetType="Label">
                <Setter Property="TextColor"      Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize"        Value="28"/>
                <Setter Property="FontAttributes" Value="Bold"/>
            </Style>

            <!-- Status pill frame -->
            <Style x:Key="StatusPill" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
                <Setter Property="BorderColor"     Value="{StaticResource BorderColor}"/>
                <Setter Property="CornerRadius"    Value="6"/>
                <Setter Property="Padding"         Value="8,3"/>
            </Style>

            <!-- Error banner frame -->
            <Style x:Key="ErrorBanner" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="#3d1515"/>
                <Setter Property="BorderColor"     Value="{StaticResource AccentRed}"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="Padding"         Value="12"/>
            </Style>

            <!-- Modal overlay card -->
            <Style x:Key="ModalCard" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
                <Setter Property="BorderColor"     Value="{StaticResource BorderColor}"/>
                <Setter Property="CornerRadius"    Value="20"/>
                <Setter Property="Padding"         Value="24"/>
                <Setter Property="HasShadow"       Value="True"/>
            </Style>

            <!-- CollectionView empty view label -->
            <Style x:Key="EmptyLabel" TargetType="Label">
                <Setter Property="TextColor"             Value="{StaticResource TextSecondary}"/>
                <Setter Property="HorizontalOptions"     Value="Center"/>
                <Setter Property="VerticalOptions"       Value="Center"/>
                <Setter Property="Margin"                Value="0,40"/>
                <Setter Property="FontSize"              Value="14"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
   
</Application>
