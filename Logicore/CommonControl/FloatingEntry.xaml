<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Logicore.CommonControl.FloatingEntry"
             x:Name="FloatingEntryContainer"
             BackgroundColor="Transparent">
    <Grid
        x:Name="MainGrid"
        HorizontalOptions="Fill"
        RowSpacing="5"
        VerticalOptions="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Padding="15,5"
            BackgroundColor="{Binding EntryBackColor}"
            HorizontalOptions="Fill"
            Stroke="{Binding BorderColor}"
            StrokeThickness="1"
            VerticalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Border.Triggers>
                <DataTrigger
                    Binding="{Binding HasLeftIcon}"
                    TargetType="Border"
                    Value="True">
                    <Setter Property="Padding"
                            Value="12,4,4,4"/>
                </DataTrigger>
                <DataTrigger
                    Binding="{Binding HasError}"
                    TargetType="Border"
                    Value="True">
                    <Setter Property="Stroke"
                            Value="Red"/>
                </DataTrigger>
                <DataTrigger
                    Binding="{Binding IsEnabled, Source={x:Reference FloatingEntryContainer}}"
                    TargetType="Border"
                    Value="False">
                    <Setter Property="Stroke"
                            Value="Gray"/>
                    <Setter Property="BackgroundColor"
                            Value="Gray"/>
                </DataTrigger>
            </Border.Triggers>
            <Grid
                ColumnSpacing="10"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.Triggers>
                    <DataTrigger TargetType="Grid" Binding="{Binding HasLeftIcon}" Value="False">
                        <Setter Property="ColumnSpacing" Value="0" />
                    </DataTrigger>
                </Grid.Triggers>
                <Image
                    Grid.Column="0"
                    Aspect="AspectFit"
                    HeightRequest="24"
                    HorizontalOptions="Start"
                    Source="{Binding LeftIconSource}"
                    IsVisible="{Binding HasLeftIcon}"
                    WidthRequest="24">
                    <Image.Triggers>
                        <DataTrigger
                            Binding="{Binding IsLeftButtonVerticallyFlipped}"
                            TargetType="Image"
                            Value="True">
                            <Setter Property="RotationY"
                                    Value="180"/>
                        </DataTrigger>
                    </Image.Triggers>
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LeftIconCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
                <Grid
                    Grid.Column="1"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center">
                    <Entry
                        x:Name="EntryField"
                       BackgroundColor="{Binding EntryBackColor}"
                        CharacterSpacing="{Binding CharacterSpacing}"
                        Completed="Handle_Completed"
                        Focused="Handle_Focused"
                        FontFamily="{Binding FontFamily}"
                        FontSize="{Binding FontSize}"
                        HorizontalTextAlignment="{Binding HorizontalTextAlignment}"
                        IsPassword="{Binding IsPassword}"
                        Keyboard="{Binding Keyboard}"
                        MaxLength="{Binding MaxLength}"
                        Placeholder="{Binding Placeholder}"
                        ReturnCommand="{Binding ReturnCommand}"
                        ReturnType="{Binding ReturnType}"
                        Text="{Binding Text}"
                        TextColor="{Binding EntryTextColor}"
                        TextChanged="EntryField_TextChanged"
                        Unfocused="Handle_Unfocused"
                        VerticalTextAlignment="{Binding VerticalTextAlignment}"/>
                    <Label
                        x:Name="LabelTitle"
                        Margin="0,10,0,0"
                        BackgroundColor="Transparent" 
                        Text="{Binding Title}"
                        TextColor="Gray"
                        VerticalOptions="Center"/>
                </Grid>
                <Image
                    Grid.Column="2"
                    Aspect="AspectFit"
                    HeightRequest="24"
                    HorizontalOptions="End"
                    IsVisible="{Binding HasRightIcon}"
                    Source="{Binding RightIconSource}"
                    VerticalOptions="Center"
                    WidthRequest="24">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding HasLeftIcon}" Value="False">
                            <Setter Property="Margin" Value="10,0,0,0" />
                        </DataTrigger>
                    </Image.Triggers>
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RightIconCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="Handle_Tapped"/>
            </Border.GestureRecognizers>
        </Border>
        <Label
            Grid.Row="1"
            HorizontalOptions="Start"
            IsVisible="{Binding HasError}"
            Text="{Binding ErrorMessage}"
            TextColor="Red"
            VerticalOptions="Start"/>
    </Grid>
</ContentView>